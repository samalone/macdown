source 'https://rubygems.org'

# Bumped from '~> 1.10' during the 2026 revival: CocoaPods 1.10 depends on
# activesupport 5.x, which needs the `mutex_m` gem that Ruby 3.4+ removed from
# the default set, so it cannot run on the modern (Ruby 4.x) toolchain.
gem 'cocoapods', '~> 1.16'

# The `travis` gem (~> 1.10) drove .travis.yml, which is defunct for this repo.
# Dropped during the revival; CI will move to GitHub Actions.
