# Release secrets, resolved from 1Password at run time.
#
# Copy this file to Tools/release.env (gitignored) and adjust the op://
# references to match your vault/item layout, then run the release script
# through `op run` so the references are resolved into the environment and
# never written to disk:
#
#     cp Tools/release.env.example Tools/release.env
#     op run --env-file=Tools/release.env -- python3 Tools/build_for_release.py
#
# `op` is the 1Password CLI (https://developer.1password.com/docs/cli/).
# Sign in first with `eval $(op signin)` (or use the desktop-app integration).

# --- Sparkle EdDSA signing key --------------------------------------------
# The private half of the EdDSA key whose public half is SUPublicEDKey in
# MacDown-Info.plist. Passed to `sign_update -s` to sign the update archive.
SPARKLE_PRIVATE_KEY=op://llama-infrastructure/macdown-sparkle/private-key

# --- Apple notarization (App Store Connect API key) -----------------------
# notarytool authenticates with an App Store Connect API key (.p8). Store the
# three parts in 1Password; the script writes the .p8 to a temp file only for
# the notarytool run and deletes it afterward.
#   key-id     : the 10-char Key ID
#   issuer-id  : the issuer UUID
#   api-key    : the full contents of the AuthKey_XXXXXXXXXX.p8 file
AC_API_KEY_ID=op://llama-infrastructure/macdown-notarytool/key-id
AC_API_ISSUER_ID=op://llama-infrastructure/macdown-notarytool/issuer-id
AC_API_KEY=op://llama-infrastructure/macdown-notarytool/api-key
